{
  "uid": "osp-observability",
  "title": "OSP / Demo services (CloudWatch)",
  "tags": [
    "osp",
    "cloudwatch",
    "demo"
  ],
  "timezone": "",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "region",
        "type": "custom",
        "query": "us-east-1,us-west-2,eu-west-1",
        "current": {
          "text": "us-east-1",
          "value": "us-east-1"
        },
        "includeAll": false
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "p95 latency by service (ms)",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "cloudwatch",
        "uid": "cloudwatch-default"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 300
              },
              {
                "color": "red",
                "value": 500
              }
            ]
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "cloudwatch",
            "uid": "cloudwatch-default"
          },
          "namespace": "osp/Demo",
          "metricName": "RequestLatencyMs",
          "dimensions": {
            "Service": "checkout"
          },
          "statistic": "p95",
          "region": "$region",
          "period": "60",
          "metricQueryType": 0,
          "metricEditorMode": 0
        },
        {
          "refId": "B",
          "datasource": {
            "type": "cloudwatch",
            "uid": "cloudwatch-default"
          },
          "namespace": "osp/Demo",
          "metricName": "RequestLatencyMs",
          "dimensions": {
            "Service": "catalog"
          },
          "statistic": "p95",
          "region": "$region",
          "period": "60",
          "metricQueryType": 0,
          "metricEditorMode": 0
        },
        {
          "refId": "C",
          "datasource": {
            "type": "cloudwatch",
            "uid": "cloudwatch-default"
          },
          "namespace": "osp/Demo",
          "metricName": "RequestLatencyMs",
          "dimensions": {
            "Service": "search"
          },
          "statistic": "p95",
          "region": "$region",
          "period": "60",
          "metricQueryType": 0,
          "metricEditorMode": 0
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Error rate % (errors / requests)",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "cloudwatch",
        "uid": "cloudwatch-default"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "refId": "errC",
          "datasource": {
            "type": "cloudwatch",
            "uid": "cloudwatch-default"
          },
          "namespace": "osp/Demo",
          "metricName": "ErrorCount",
          "dimensions": {
            "Service": "checkout"
          },
          "statistic": "Sum",
          "region": "$region",
          "period": "60",
          "hide": true,
          "metricQueryType": 0,
          "metricEditorMode": 0
        },
        {
          "refId": "reqC",
          "datasource": {
            "type": "cloudwatch",
            "uid": "cloudwatch-default"
          },
          "namespace": "osp/Demo",
          "metricName": "RequestCount",
          "dimensions": {
            "Service": "checkout"
          },
          "statistic": "Sum",
          "region": "$region",
          "period": "60",
          "hide": true,
          "metricQueryType": 0,
          "metricEditorMode": 0
        },
        {
          "refId": "rateC",
          "datasource": {
            "type": "__expr__",
            "uid": "__expr__"
          },
          "type": "math",
          "expression": "100 * $errC / $reqC",
          "label": "checkout"
        },
        {
          "refId": "errCat",
          "datasource": {
            "type": "cloudwatch",
            "uid": "cloudwatch-default"
          },
          "namespace": "osp/Demo",
          "metricName": "ErrorCount",
          "dimensions": {
            "Service": "catalog"
          },
          "statistic": "Sum",
          "region": "$region",
          "period": "60",
          "hide": true,
          "metricQueryType": 0,
          "metricEditorMode": 0
        },
        {
          "refId": "reqCat",
          "datasource": {
            "type": "cloudwatch",
            "uid": "cloudwatch-default"
          },
          "namespace": "osp/Demo",
          "metricName": "RequestCount",
          "dimensions": {
            "Service": "catalog"
          },
          "statistic": "Sum",
          "region": "$region",
          "period": "60",
          "hide": true,
          "metricQueryType": 0,
          "metricEditorMode": 0
        },
        {
          "refId": "rateCat",
          "datasource": {
            "type": "__expr__",
            "uid": "__expr__"
          },
          "type": "math",
          "expression": "100 * $errCat / $reqCat",
          "label": "catalog"
        },
        {
          "refId": "errS",
          "datasource": {
            "type": "cloudwatch",
            "uid": "cloudwatch-default"
          },
          "namespace": "osp/Demo",
          "metricName": "ErrorCount",
          "dimensions": {
            "Service": "search"
          },
          "statistic": "Sum",
          "region": "$region",
          "period": "60",
          "hide": true,
          "metricQueryType": 0,
          "metricEditorMode": 0
        },
        {
          "refId": "reqS",
          "datasource": {
            "type": "cloudwatch",
            "uid": "cloudwatch-default"
          },
          "namespace": "osp/Demo",
          "metricName": "RequestCount",
          "dimensions": {
            "Service": "search"
          },
          "statistic": "Sum",
          "region": "$region",
          "period": "60",
          "hide": true,
          "metricQueryType": 0,
          "metricEditorMode": 0
        },
        {
          "refId": "rateS",
          "datasource": {
            "type": "__expr__",
            "uid": "__expr__"
          },
          "type": "math",
          "expression": "100 * $errS / $reqS",
          "label": "search"
        }
      ]
    },
